# Configuración de PostgreSQL
POSTGRES_USER=meraki_user
POSTGRES_PASSWORD=meraki_secure_password_2026
POSTGRES_DB=meraki_db
POSTGRES_HOST=database
POSTGRES_PORT=5432

# URL de Base de Datos para SQLAlchemy (asíncrona y síncrona para Alembic)
DATABASE_URL=postgresql+asyncpg://meraki_user:meraki_secure_password_2026@database:5432/meraki_db
DATABASE_SYNC_URL=postgresql+psycopg2://meraki_user:meraki_secure_password_2026@database:5432/meraki_db

# Seguridad y Autenticación JWT
# OBLIGATORIO y sin valor por defecto en el código. Genera uno único, p. ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CAMBIAR_por_un_secreto_unico_y_aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Entorno: development | production. En production se deshabilita /docs, /redoc y /openapi.json.
ENVIRONMENT=development
# CORS: en production fija orígenes explícitos, p. ej. BACKEND_CORS_ORIGINS=["https://tu-dominio.com"]
# BACKEND_CORS_ORIGINS=["*"]

# Administrador Inicial (Semilla)
# ADMIN_PASSWORD es OBLIGATORIO y sin valor por defecto en el código.
ADMIN_USERNAME=admin
ADMIN_EMAIL=expo360.meraki@gmail.com
ADMIN_PASSWORD=CAMBIAR_por_una_contrasena_fuerte

# Configuración de la Actividad (Semilla)
EVENT_NAME=Expo 360 Meraki
EVENT_ORGANIZER=Carrera de Diseño Gráfico
EVENT_CONTACT_EMAIL=expo360.meraki@gmail.com
EVENT_DATE=2026-08-16
EVENT_START_TIME=10:00:00
EVENT_END_TIME=18:00:00
EVENT_LOCATION=Centro de Convenciones, Salón de Exposiciones
EVENT_MAX_PARTICIPANTS=200
EVENT_REGISTRATION_DEADLINE=2026-08-15T23:59:59
EVENT_STATUS=active
